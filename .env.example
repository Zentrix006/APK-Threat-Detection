# Database Configuration
DB_USER=apk_user
DB_PASSWORD=apk_password
DB_NAME=apk_threat
DATABASE_URL=postgresql://apk_user:apk_password@postgres:5432/apk_threat

# Redis Configuration
REDIS_PASSWORD=redis_password
REDIS_URL=redis://:redis_password@redis:6379/0

# JWT & Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=86400
CORS_ORIGINS=http://localhost:3000,http://localhost,https://yourdomain.com

# API Keys (External Services)
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
URLHAUS_API_KEY=

# Ollama & AI Configuration
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen3
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=2048

# Analysis Configuration
ANDROID_SDK_PATH=/opt/android-sdk
FRIDA_SERVER_PORT=27042
FRIDA_VERSION=latest
APK_MAX_SIZE=500  # MB
ANALYSIS_TIMEOUT=600  # seconds

# Analysis Tools Paths
MOBSF_PATH=/opt/mobile-security-framework
APKTOOL_PATH=/opt/apktool
JADX_PATH=/opt/jadx
ANDROGUARD_PATH=/opt/androguard

# Dynamic Analysis
EMULATOR_ENABLED=false
EMULATOR_HOST=android-emulator
EMULATOR_ADB_PORT=5555
NETWORK_CAPTURE_ENABLED=true
TCPDUMP_INTERFACE=eth0

# Storage Configuration
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=500000000  # 500MB in bytes
STORAGE_TYPE=local  # local, s3, gcs

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/app.log

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=APK Threat Intelligence Platform
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# Email Configuration (for report delivery)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@apkthreat.local

# Environment
ENVIRONMENT=development
DEBUG=false
ALLOW_ADMIN_PANEL=true

# Workers & Performance
WORKERS=4
WORKER_THREADS=2
BATCH_SIZE=10
CACHE_TTL=3600

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # seconds

# Mobile Device Configuration
ANDROID_MIN_API=28
ANDROID_TARGET_API=34
ANDROID_DEVICE_NAME=emulator-5554

# MITRE ATT&CK Configuration
MITRE_DB_PATH=/opt/mitre-attack-db
MITRE_ENABLED=true

# ML Model Configuration
XGBOOST_MODEL_PATH=./models/risk_scorer.pkl
MODEL_CONFIDENCE_THRESHOLD=0.7
RETRAIN_FREQUENCY=604800  # Weekly in seconds

# Backup & Maintenance
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # 2 AM daily
RETENTION_DAYS=90
